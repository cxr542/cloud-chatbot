# 관리자 로그인 정보 (포트 8001 접근용)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cloud1234!

# Gemini (Google AI) API 키 — 코드는 아래 이름 중 하나만 넣으면 됩니다.
# LLM_API_KEY=your_key_here
# 또는 GOOGLE_API_KEY / GEMINI_API_KEY (동일하게 인식)
LLM_API_KEY=your_api_key_here

# run.py 가 uvicorn 에 넘기는 --host 입니다. 기본(미설정)은 코드상 "::" 입니다.
# Windows 등에서 --host :: 가 안 되면 UVICORN_HOST=127.0.0.1 로 두고 주소창도 127.0.0.1 을 쓰세요.
# UVICORN_HOST=::
#
# 같은 Wi-Fi의 다른 기기에서 http://이맥의IP:9999 로 접속하려면 IPv4 전체 인터페이스에 바인딩하세요.
# .env 에 아래 한 줄을 넣은 뒤 run.py 를 다시 실행합니다(환경 변수는 --reload 로 안 잡힐 수 있음).
# UVICORN_HOST=0.0.0.0
# macOS: 시스템 설정 → 네트워크 → 방화벽에서 터미널/python 의 들어오는 연결이 막혀 있으면 허용이 필요할 수 있습니다.

# 데이터베이스 파일 경로
DB_PATH=chatbot_data.db

# (선택) 배포·재시작 시 DB가 기본 챗봇 성격 문구만 있을 때 채울 프롬프트 — 파일 우선 경로(기본 my_prompt.txt)
# SYSTEM_PROMPT_FILE=my_prompt.txt
# (선택) 위 파일 대신 환경 변수로 전체 프롬프트 지정(한 줄이 아니면 Render Secret File 검토)
# SYSTEM_PROMPT=

# 로컬 RAG 임베딩(HuggingFace 모델 이름). sentence-transformers 가 처음에 모델을 내려받을 수 있습니다.
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 동영상 업로드 시 Gemini 클라우드 처리 대기(초). 기본 420. 업로드는 됐는데 요약만 비는 경우 늘리기.
# VIDEO_GEMINI_WAIT_SEC=420

# 동영상 요약에 쓸 Gemini 모델 이름(멀티모달). 기본 gemini-2.5-flash. 빈 응답이 반복되면 gemini-2.0-flash 등으로 시도.
# GEMINI_VIDEO_MODEL=gemini-2.5-flash

# 동영상 요약 API 한 번 호출이 끝날 때까지 기다리는 최대 시간(초). 기본 1800(30분). peer 504이면 GEMINI_VIDEO_UNARY_ATTEMPTS·GEMINI_VIDEO_RETRY_WAIT_SEC 과 함께 조정.
# GEMINI_VIDEO_RPC_TIMEOUT_SEC=1800

# unary 요약 호출 재시도 횟수(DeadlineExceeded 또는 빈 본문 대비). 기본 4.
# GEMINI_VIDEO_UNARY_ATTEMPTS=4

# 각 재시도 전 대기(초). 기본 60.
# GEMINI_VIDEO_RETRY_WAIT_SEC=60

# 관리자 동영상 파일 크기 상한(MB). 한 번에 메모리로 읽습니다. 기본값은 코드 내 256(미기입 시). 최대 512.
# 줄 끝 주석 허용: MAX_VIDEO_UPLOAD_MB=300  # 예시
# MAX_VIDEO_UPLOAD_MB=256

# 나만의 이모티콘(`/api/sticker-pack`) — Gemini 네이티브 이미지 모델(예: nano banana 라인).
# GEMINI_STICKER_MODEL=gemini-2.5-flash-image
# 참조 사진 업로드 상한(MB)
# MAX_STICKER_UPLOAD_MB=8
# 패널 한 장이 텍스트로만 응답할 때 포함·최대 시도 횟수(기본 코드값 3, 처음 포함).
# GEMINI_STICKER_PANEL_ATTEMPTS=3